# ZnDraw Docker Configuration
# CHANGE ALL VALUES BELOW before deploying!

# --- Secrets (MUST change in production) ---
ZNDRAW_GUEST_PASSWORD=zndraw
ZNDRAW_WORKER_PASSWORD=zndraw-worker
ZNDRAW_AUTH_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-SECRET!
ZNDRAW_AUTH_RESET_PASSWORD_TOKEN_SECRET=CHANGE-ME-RESET
ZNDRAW_AUTH_VERIFICATION_TOKEN_SECRET=CHANGE-ME-VERIFY

# --- Admin User ---
ZNDRAW_AUTH_DEFAULT_ADMIN_EMAIL=admin@zndraw.local
ZNDRAW_AUTH_DEFAULT_ADMIN_PASSWORD=admin
